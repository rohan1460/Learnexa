// This is your Prisma schema file

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  notes         StudyNote[]
  quizzes       Quiz[]
  flashcards    Flashcard[]
  weaknesses    WeaknessRecord[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model StudyNote {
  id        String      @id @default(cuid())
  userId    String
  title     String
  content   String      // The text content or transcription
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks    NoteChunk[]
}

model NoteChunk {
  id        String    @id @default(cuid())
  noteId    String
  content   String
  embedding String?   // JSON-serialized float array for local vector similarity
  createdAt DateTime  @default(now())
  note      StudyNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

model Quiz {
  id             String         @id @default(cuid())
  userId         String
  topic          String
  difficulty     String         @default("medium") // easy | medium | hard
  score          Int?
  totalQuestions Int            @default(5)
  createdAt      DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions      QuizQuestion[]
}

model QuizQuestion {
  id         String   @id @default(cuid())
  quizId     String
  type       String   // "mcq" | "short" | "long" | "viva"
  question   String
  options    String?  // JSON array for MCQs e.g. '["A","B","C","D"]'
  answer     String   // Correct answer
  userAnswer String?
  isCorrect  Boolean?
  timeTaken  Int?     // seconds
  quiz       Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model Flashcard {
  id          String   @id @default(cuid())
  userId      String
  noteId      String?
  front       String
  back        String
  easeFactor  Float    @default(2.5)
  interval    Int      @default(1)   // days until next review
  repetitions Int      @default(0)
  nextReview  DateTime @default(now())
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeaknessRecord {
  id         String   @id @default(cuid())
  userId     String
  topic      String
  wrongCount Int      @default(0)
  totalCount Int      @default(0)
  avgTime    Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topic])
}
